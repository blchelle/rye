{
  "name": "rye",
  "version": "0.0.1",
  "description": "Eye rest reminder app",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build:web": "vite build",
    "start": "electron .",
    "build": "npm run build:web && electron-builder --mac"
  },
  "keywords": [
    "electron",
    "eye-rest"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "electron-store": "^8.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "vite": "^5.0.8"
  },
  "build": {
    "appId": "com.rye.eyerest",
    "productName": "Rye",
    "files": [
      "main.js",
      "preload.js",
      "preload-settings.js",
      "detect-screen-share",
      "dist/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "detect-screen-share"
    ],
    "extraResources": [
      {
        "from": "build",
        "to": "build",
        "filter": ["tray*.png"]
      }
    ],
    "mac": {
      "category": "public.app-category.healthcare-fitness",
      "target": "dmg",
      "icon": "build/icon.icns",
      "entitlements": "entitlements.mac.plist",
      "extendInfo": {
        "LSUIElement": true,
        "NSScreenCaptureDescription": "Rye needs screen recording permission to detect when you're sharing your screen, so it can skip reminders during presentations."
      }
    }
  }
}
